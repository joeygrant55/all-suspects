ANTHROPIC_API_KEY=

# Frontend API base. Leave unset in production if you rely on same-origin /api rewrites.
VITE_API_URL=http://localhost:3001

# Optional: enable saint reply playback with ElevenLabs.
ELEVENLABS_API_KEY=
ELEVENLABS_MODEL_ID=eleven_flash_v2_5
ELEVENLABS_DEFAULT_VOICE_ID=

# Optional saint-specific overrides.
ELEVENLABS_VOICE_ID_AQUINAS=
ELEVENLABS_VOICE_ID_AUGUSTINE=
ELEVENLABS_VOICE_ID_THERESE=
ELEVENLABS_VOICE_ID_IGNATIUS=
ELEVENLABS_VOICE_ID_FRANCIS_DE_SALES=
